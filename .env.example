# =============================================================================
# Environment Variables Template for Coub Downloader
# Author: Vladyslav Zaiets | https://sarmkadan.com
#
# Copy this file to .env and update values for your environment
# =============================================================================

# Application Settings
COUB_OUTPUT_PATH=./downloads
COUB_CACHE_PATH=./cache
COUB_LOG_LEVEL=Information
COUB_LOG_FILE=./logs/app.log

# Conversion Settings
COUB_DEFAULT_QUALITY=High
COUB_DEFAULT_FORMAT=MP4
COUB_DEFAULT_FPS=30
COUB_ENABLE_HW_ACCELERATION=false

# GPU Codec Options (if hardware acceleration enabled)
# Options: h264_nvenc (NVIDIA), hevc_amf (AMD), hevc_qsv (Intel)
COUB_GPU_CODEC=h264_nvenc

# FFmpeg Settings
COUB_FFMPEG_PATH=/usr/bin/ffmpeg
COUB_FFPROBE_PATH=/usr/bin/ffprobe
COUB_FFMPEG_THREADS=4

# Audio Settings
COUB_AUDIO_LOOP_STRATEGY=Repeat
COUB_AUDIO_SAMPLE_RATE=44100
COUB_AUDIO_CHANNELS=2
COUB_AUDIO_BITRATE=128

# API Settings
COUB_API_BASE_URL=https://coub.com
COUB_API_TIMEOUT_SECONDS=30
COUB_RATE_LIMIT_PER_MINUTE=60
COUB_VERIFY_SSL=true

# Retry Policy
COUB_MAX_RETRIES=3
COUB_RETRY_INITIAL_DELAY_MS=1000
COUB_RETRY_MAX_DELAY_MS=30000
COUB_RETRY_BACKOFF_MULTIPLIER=2.0

# Caching
COUB_ENABLE_CACHING=true
COUB_MAX_CACHE_SIZE_GB=1.0
COUB_CACHE_EXPIRY_HOURS=24

# Performance
COUB_PARALLEL_DOWNLOADS=4
COUB_MAX_MEMORY_MB=2048

# Logging
COUB_ENABLE_DETAILED_LOGGING=false
COUB_LOG_REQUESTS=false
COUB_LOG_RESPONSES=false

# Storage (for cloud deployments)
COUB_STORAGE_TYPE=local
# COUB_STORAGE_TYPE=s3
# COUB_S3_BUCKET=my-bucket
# COUB_S3_REGION=us-east-1
# COUB_S3_ACCESS_KEY=xxx
# COUB_S3_SECRET_KEY=xxx

# Proxy Settings (if needed)
COUB_HTTP_PROXY=
COUB_HTTPS_PROXY=
COUB_NO_PROXY=localhost,127.0.0.1

# Security
COUB_API_KEY=
COUB_API_SECRET=

# Webhooks
COUB_WEBHOOK_ENABLED=false
COUB_WEBHOOK_URL=
COUB_WEBHOOK_SECRET=

# Monitoring
COUB_ENABLE_METRICS=false
COUB_METRICS_PORT=5000
COUB_HEALTH_CHECK_INTERVAL_SECONDS=30

# Docker specific
COUB_DOCKER_MODE=false
